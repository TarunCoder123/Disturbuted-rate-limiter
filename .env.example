# ── Application ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Rate Limiter Defaults ─────────────────────────────────────────────────────
RL_REFILL_RATE=10       # tokens per second
RL_CAPACITY=20          # max bucket size (burst)
RL_TTL_SECONDS=3600     # Redis key expiry (seconds)
RL_KEY_PREFIX=rate_limit
